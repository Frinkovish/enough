SUPABASE_URL=https://your-project.supabase.co
CORS_ORIGINS=[]
# Flutter web's dev port changes per run; allow any localhost port in dev.
# Set CORS_ORIGINS to your real frontend origin(s) and drop this in production.
CORS_ORIGIN_REGEX=http://(localhost|127\.0\.0\.1):\d+
# Azure's newer Responses API — no deployment name in the URL; it goes
# in AZURE_OPENAI_MODEL instead (must match a model actually deployed
# on your resource, not just listed as available).
AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com/openai/v1/responses
AZURE_OPENAI_API_KEY=replace-with-your-azure-openai-key
AZURE_OPENAI_MODEL=gpt-4o-mini

# Daily reminder (personal use, single recipient) — sent via a Telegram
# bot and triggered by the daily-reminder GitHub Actions workflow hitting
# POST /api/v1/reminders/daily. No approval process or message templates
# needed, unlike WhatsApp's Business Platform.
# 1. Message @BotFather on Telegram, send /newbot, follow the prompts —
#    it gives you a token like the one below.
# 2. Message your new bot anything (e.g. "hi") so it can see your chat.
# 3. Visit https://api.telegram.org/bot<TOKEN>/getUpdates in a browser —
#    your chat id is the number at result[0].message.chat.id.
TELEGRAM_BOT_TOKEN=123456789:replace-with-your-bot-token
TELEGRAM_CHAT_ID=replace-with-your-chat-id
# Whichever Supabase user_id's profile (quit_date/days_clean_target) the
# reminder should read from — optional; omit for a generic message.
REMINDER_USER_ID=00000000-0000-0000-0000-000000000000
# Service role / secret key (Supabase dashboard > Settings > API) —
# bypasses RLS. Must be the service_role/secret key, NOT the
# anon/publishable one, or the profile lookup silently returns nothing.
# Keep this out of the frontend; it's backend-only.
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-supabase-service-role-key
# Shared secret the GitHub Actions workflow sends as X-Reminder-Secret.
# Generate any random string (e.g. `openssl rand -hex 32`).
REMINDER_SECRET=replace-with-a-random-secret
# IANA timezone (e.g. Africa/Tunis, Europe/Paris) so the AI-written
# message can reference the actual time of day for you. Defaults to UTC.
REMINDER_TIMEZONE=UTC
