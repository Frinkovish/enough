SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# FastAPI backend, used for optional enhancements (e.g. AI suggestions).
# The app falls back to local logic if it's unset or unreachable.
# Testing on a phone over LAN: use your machine's LAN IP instead of
# localhost (e.g. http://192.168.1.18:8000) — the phone's "localhost"
# is itself, not your dev machine.
BACKEND_BASE_URL=http://localhost:8000
